rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transactions
    // Fields:
    //   - type: string (income/expense)
    //   - amount: number
    //   - category: string (business/home)
    //   - subcategory: string
    //   - description: string (optional)
    //   - date: string (ISO 8601)
    //   - monthYear: string (YYYY-MM)
    //   - uid: string
    //   - supplierId: string (optional)
    //
    // Collection: suppliers
    // Fields:
    //   - name: string
    //   - uid: string
    //   - createdAt: string
    //
    // Collection: monthlyClosures
    // Fields:
    //   - monthYear: string
    //   - totalIncome: number
    //   - totalBusinessExpenses: number
    //   - totalHomeExpenses: number
    //   - balance: number
    //   - timestamp: string
    //   - uid: string
    //
    // Collection: settings
    // Fields:
    //   - fixedExpensesGoal: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidTransaction(data) {
      return data.type in ['income', 'expense'] &&
             data.amount is number && data.amount >= 0 &&
             data.category in ['business', 'home'] &&
             data.subcategory is string && data.subcategory.size() > 0 &&
             data.date is string &&
             data.monthYear is string && data.monthYear.matches('^\\d{4}-\\d{2}$') &&
             data.uid == request.auth.uid &&
             (!('supplierId' in data) || data.supplierId is string);
    }

    function isValidSupplier(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uid == request.auth.uid &&
             data.createdAt is string;
    }

    function isValidClosure(data) {
      return data.monthYear is string &&
             data.totalIncome is number &&
             data.totalBusinessExpenses is number &&
             data.totalHomeExpenses is number &&
             data.balance is number &&
             data.timestamp is string &&
             data.uid == request.auth.uid;
    }

    function isValidCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type in ['income', 'expense'] &&
             data.category in ['business', 'home'] &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /transactions/{transactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isDocOwner() && isValidTransaction(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /monthlyClosures/{closureId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidClosure(request.resource.data);
      allow update: if false; // Closures are historical and immutable
      allow delete: if false;
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // For simplicity, any auth user can update settings
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCategory(request.resource.data);
      allow update: if isDocOwner() && isValidCategory(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSupplier(request.resource.data);
      allow update: if isDocOwner() && isValidSupplier(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
